PORT=3000
NODE_ENV=production

# 建议填写 Tailscale 主机名或私网地址，例如：
# APP_BASE_URL=http://100.88.10.23:3000
APP_BASE_URL=http://your-private-hostname:3000

# 最小访问保护，团队值班时务必开启
CONSOLE_AUTH_USERNAME=broker
CONSOLE_AUTH_PASSWORD=change-this-strong-password

STORE_STATE_FILE=.data/console-state.json
STORE_AUDIT_FILE=.data/audit-log.ndjson
STORE_AUTOSAVE_DEBOUNCE_MS=150

WHATSAPP_AUTH_DIR=.sessions/whatsapp-baileys
WHATSAPP_CLIENT_ID=primary
WHATSAPP_BROWSER_NAME=SupplyConsolePro
WHATSAPP_BROWSER_PATH=
WHATSAPP_HEADLESS=true
WHATSAPP_DEFAULT_PAIRING_PHONE=
WHATSAPP_PRINT_QR=false
WHATSAPP_JITTER_MIN_MS=500
WHATSAPP_JITTER_MAX_MS=1500
WHATSAPP_MAX_QUEUE_SIZE=100
WHATSAPP_BREAKER_FAILURE_THRESHOLD=5
WHATSAPP_BREAKER_COOLDOWN_MS=30000
WHATSAPP_RECONNECT_DELAY_MS=3000
WHATSAPP_MAX_RECONNECT_ATTEMPTS=0
WHATSAPP_DISCOVERY_FILE=.sessions/whatsapp-baileys/_discovered-chats.json
WHATSAPP_DISCOVERY_AUTOSAVE_DEBOUNCE_MS=200

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_FILE=.sessions/telegram-userbot.json
TELEGRAM_SESSION_SECRET=change-this-telegram-session-secret
